{
  "name": "brand-it",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "typecheck": "tsc --noEmit",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "test": "vitest run",
    "check": "pnpm lint && pnpm typecheck && pnpm templates:compile && pnpm templates:validate",
    "templates:compile": "tsx scripts/compile-templates.ts",
    "templates:validate": "tsx scripts/validate-templates.ts"
  },
  "dependencies": {
    "@tanstack/react-router": "^1.170.8",
    "@tanstack/react-start": "^1.168.14",
    "hono": "^4.7.7",
    "motion": "^12.15.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "zod": "^3.24.4"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.0.0",
    "@cloudflare/vite-plugin": "^1.39.0",
    "@cloudflare/workers-types": "^4.20250525.0",
    "@tailwindcss/vite": "^4.3.0",
    "@tanstack/router-devtools": "^1.167.0",
    "@tanstack/start-vite-plugin": "^1.91.1",
    "@types/node": "^25.9.1",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "gray-matter": "^4.0.3",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "vite": "^6.3.5",
    "vitest": "^3.2.2",
    "wrangler": "^4.95.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "sharp",
      "workerd"
    ]
  }
